---
layout: none
permalink: /search.json
---
[
  {%- assign documents = site.posts | concat: site.pages -%}
  {%- assign first = true -%}
  {%- for doc in documents -%}
    {%- if doc.title -%}
      {%- unless first -%},{%- endunless -%}
      {%- assign first = false -%}
      {
        "title"    : {{ doc.title | jsonify }},
        "category" : {{ doc.category | jsonify }},
        "tags"     : {{ doc.tags | join: ', ' | jsonify }},
        "url"      : {{ doc.url | relative_url | jsonify }},
        "date"     : {{ doc.date | date: "%B %d, %Y" | jsonify }},
        "excerpt"  : {{ doc.excerpt | strip_html | strip_newlines | truncatewords: 30 | jsonify }},
        "content"  : {{ doc.content | strip_html | strip_newlines | truncatewords: 50 | jsonify }},
        "lang"     : {{ doc.lang | default: "fr" | jsonify }}
      }
    {%- endif -%}
  {%- endfor -%}
]
